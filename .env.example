# ============================================================
# EDULITE MOBILE APP — Environment Variables
# ============================================================
# Copy this file to .env and fill in the values.
#   cp .env.example .env
#
# ⚠️  .env is gitignored — NEVER commit the real .env file.
# ============================================================

# -------------------------------------------------------
# API
# -------------------------------------------------------
# Base URL of the backend REST API
VITE_API_BASE_URL=http://localhost:3000

# API request timeout in milliseconds
VITE_API_TIMEOUT=10000

# -------------------------------------------------------
# App
# -------------------------------------------------------
VITE_APP_NAME=Edulite Mobile
VITE_APP_VERSION=1.0.0

# App environment: development | staging | production
VITE_APP_ENV=development

# -------------------------------------------------------
# Feature Flags
# -------------------------------------------------------
# Enable debug mode (shows verbose logs)
VITE_DEBUG=true

# Enable mock API (uses local mock data instead of real API)
VITE_USE_MOCK=false
